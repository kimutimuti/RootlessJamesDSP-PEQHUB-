<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/shape_rounded_rectangle"
        android:backgroundTint="?attr/colorOnSurfaceVariant" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="@string/peq_live_eq"
        android:textAppearance="?attr/textAppearanceTitleMedium" />

    <!-- Frequency response preview -->
    <me.timschneeberger.rootlessjamesdsp.view.ParametricEqSurface
        android:id="@+id/liveEqSurface"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp" />

    <!-- Band selector chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/bandChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            app:singleLine="true"
            app:selectionRequired="false"
            app:singleSelection="true" />

    </HorizontalScrollView>

    <!-- "Tap a band" hint shown when no band is selected -->
    <TextView
        android:id="@+id/liveEqHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"
        android:text="@string/peq_live_eq_hint"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <!-- Sliders section — hidden until a band is selected -->
    <LinearLayout
        android:id="@+id/slidersSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/peq_frequency"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.slider.Slider
            android:id="@+id/freqSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="0"
            app:labelBehavior="floating" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/peq_gain"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.slider.Slider
            android:id="@+id/gainSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="-30"
            android:valueTo="30"
            android:stepSize="0.1"
            app:labelBehavior="floating" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/peq_q_factor"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <com.google.android.material.slider.Slider
            android:id="@+id/qSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="0"
            app:labelBehavior="floating" />

    </LinearLayout>

</LinearLayout>
